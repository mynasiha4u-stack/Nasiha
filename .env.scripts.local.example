# Local secrets file for the Node scripts in scripts/*.
# Copy this file to `.env.scripts.local` (drop the `.example` suffix) and fill in your real keys.
# The real file is .gitignored — keys never get committed.
#
# Get each key:
#   GOOGLE_MAPS_API_KEY — your "Nasiha Server (Geocoding)" key from GCP (starts with AIza)
#   ANTHROPIC_API_KEY   — Anthropic console.anthropic.com → API Keys (starts with sk-ant-)
#   OPENAI_API_KEY      — platform.openai.com → API Keys (starts with sk-proj-)
#   SUPABASE_SERVICE_ROLE_KEY — Supabase Project Settings → API → service_role (starts with eyJ)

GOOGLE_MAPS_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
